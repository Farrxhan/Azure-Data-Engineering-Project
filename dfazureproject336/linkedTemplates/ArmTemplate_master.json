{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfazureproject336"
		},
		"Azure_ADLS_Project_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Azure_ADLS_Project'"
		},
		"Azure_sql_Project_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Azure_sql_Project'"
		},
		"Azure_ADLS_Project_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageazure336.dfs.core.windows.net/"
		},
		"Azure_sql_Project_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azureproject336.database.windows.net"
		},
		"Azure_sql_Project_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfarhan"
		},
		"Azure_sql_Project_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "farhan"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfazureproject336_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Azure_ADLS_Project_accountKey": {
						"value": "[parameters('Azure_ADLS_Project_accountKey')]"
					},
					"Azure_sql_Project_password": {
						"value": "[parameters('Azure_sql_Project_password')]"
					},
					"Azure_ADLS_Project_properties_typeProperties_url": {
						"value": "[parameters('Azure_ADLS_Project_properties_typeProperties_url')]"
					},
					"Azure_sql_Project_properties_typeProperties_server": {
						"value": "[parameters('Azure_sql_Project_properties_typeProperties_server')]"
					},
					"Azure_sql_Project_properties_typeProperties_database": {
						"value": "[parameters('Azure_sql_Project_properties_typeProperties_database')]"
					},
					"Azure_sql_Project_properties_typeProperties_userName": {
						"value": "[parameters('Azure_sql_Project_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}